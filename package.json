{
  "name": "auto-cli",
  "version": "0.33.0",
  "description": "Auto CLI - Claude Code /auto 超级命令",
  "scripts": {
    "pack": "npm pack",
    "install": "node scripts/install.js",
    "uninstall": "node scripts/uninstall.js",
    "reinstall": "bash scripts/reinstall.sh",
    "sync": "node scripts/install.js",
    "format": "prettier --write \"commands/**/*.md\" \"agents/**/*.md\" \"skills/**/*.md\"",
    "format:check": "prettier --check \"commands/**/*.md\" \"agents/**/*.md\" \"skills/**/*.md\"",
    "validate:references": "node scripts/validate-references.js",
    "check": "npm run format:check && npm run validate:references",
    "test": "npm run check"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "agents",
    "workflow",
    "automation"
  ],
  "author": "Auto CLI Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ktyyer/auto-cli"
  },
  "bugs": {
    "url": "https://github.com/ktyyer/auto-cli/issues"
  },
  "homepage": "https://github.com/ktyyer/auto-cli#readme",
  "files": [
    "scripts",
    "agents",
    "rules",
    "commands",
    "skills",
    "hooks"
  ],
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "prettier": "^3.8.1"
  }
}
